description: |
    Runs rpminspect tests in CentOS Stream 9 — https://github.com/fedora-ci/rpminspect-pipeline (branch: c9s)

provision:
    how: container
    # source: https://github.com/fedora-ci/rpminspect-image (Dockerfile.stream)
    image: quay.io/fedoraci/rpminspect:stream-a809f05

prepare:
    how: shell
    script: |
        if [ -z "$REPO_URL" ]; then
            echo "REPO_URL not specified"
            exit 1
        fi

execute:
    how: tmt

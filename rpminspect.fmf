summary: tmt plan for rpminspect.

discover:
    how: shell
    tests:
    - name: license
      framework: shell
      test: /usr/local/bin/rpminspect_zuul_runner.sh -r $REPO_URL -t license -e
      duration: 720m
    - name: emptyrpm
      framework: shell
      test: /usr/local/bin/rpminspect_zuul_runner.sh --cached -t emptyrpm
      duration: 2m
    - name: lostpayload
      framework: shell
      test: /usr/local/bin/rpminspect_zuul_runner.sh --cached -t lostpayload
      duration: 2m
    - name: metadata
      framework: shell
      test: /usr/local/bin/rpminspect_zuul_runner.sh --cached -t metadata
      duration: 2m
    - name: manpage
      framework: shell
      test: /usr/local/bin/rpminspect_zuul_runner.sh --cached -t manpage
      duration: 2m
    - name: xml
      framework: shell
      test: /usr/local/bin/rpminspect_zuul_runner.sh --cached -t xml
      duration: 2m
    - name: elf
      framework: shell
      test: /usr/local/bin/rpminspect_zuul_runner.sh --cached -t elf
      duration: 2m
    - name: desktop
      framework: shell
      test: /usr/local/bin/rpminspect_zuul_runner.sh --cached -t desktop
      duration: 2m
    - name: disttag
      framework: shell
      test: /usr/local/bin/rpminspect_zuul_runner.sh --cached -t disttag
      duration: 2m
    - name: specname
      framework: shell
      test: /usr/local/bin/rpminspect_zuul_runner.sh --cached -t specname
      duration: 2m
    - name: modularity
      framework: shell
      test: /usr/local/bin/rpminspect_zuul_runner.sh --cached -t modularity
      duration: 2m
    - name: javabytecode
      framework: shell
      test: /usr/local/bin/rpminspect_zuul_runner.sh --cached -t javabytecode
      duration: 2m
    - name: changedfiles
      framework: shell

    - name: dsodeps
      framework: shell
      test: /usr/local/bin/rpminspect_zuul_runner.sh --cached -t dsodeps
      duration: 2m
    - name: filesize
      framework: shell
      test: /usr/local/bin/rpminspect_zuul_runner.sh --cached -t filesize
